{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "employees_route": {
        "ClusterId": "employees_cluster",
        "Match": {
          "Path": "/api/employees/{**catch-all}"
        }
      },
      "employees-swagger": {
        "ClusterId": "swagger-employees-cluster",
        "Match": {
          "Path": "/swagger/api/employees/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "payroll_route": {
        "ClusterId": "payroll_cluster",
        "Match": {
          "Path": "/api/payroll/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "employees_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7075"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "swagger-employees-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7075"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      },
      "payroll_cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7205"
          }
        },
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        }
      }
    }
  }
}
